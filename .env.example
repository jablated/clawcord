# Discord
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here

# OpenClaw Gateway
OPENCLAW_GATEWAY_URL=ws://localhost:18788
OPENCLAW_GATEWAY_TOKEN=

# ---------------------------------------------------------------------------
# STT (Speech-to-Text)
# Providers: "local-whisper" | "openai-whisper" | "openai-compatible"
# ---------------------------------------------------------------------------
STT_PROVIDER=local-whisper

# For local-whisper: model size passed to the `whisper` CLI
# Options: tiny, base, small, medium, large (append .en for English-only, e.g. base.en)
# Install: pip install openai-whisper
STT_MODEL=base.en

# For openai-compatible: base URL of the STT server (e.g. a faster-whisper HTTP server)
# STT_BASE_URL=http://192.168.0.x:9000/v1

# ---------------------------------------------------------------------------
# TTS (Text-to-Speech)
# Providers: "piper" | "openai-tts" | "openai-compatible"
# ---------------------------------------------------------------------------
TTS_PROVIDER=piper

# Piper voice model name (must be downloaded to TTS_PIPER_MODEL_DIR)
# Run scripts/setup-piper.sh to install piper and download the default voice
TTS_VOICE=en_US-lessac-medium

# Path to the piper binary (defaults to 'piper' on PATH)
# TTS_PIPER_PATH=piper

# Directory containing piper .onnx voice model files
# TTS_PIPER_MODEL_DIR=~/.local/share/piper/models

# For openai-compatible TTS: base URL of the TTS server (e.g. Kokoro-FastAPI)
# TTS_BASE_URL=http://192.168.0.x:8880/v1

# Voice name for openai / openai-compatible TTS
# TTS_OPENAI_VOICE=nova

# ---------------------------------------------------------------------------
# OpenAI API key — only required when using openai-whisper or openai-tts providers
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
